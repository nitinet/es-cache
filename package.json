{
  "name": "es-cache",
  "version": "1.11.2",
  "description": "A simple in-memory cache on ecmascript 6 and typescript.",
  "types": "./src/index.ts",
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "clean": "rm -rf ./src/**/*.js ./tsconfig.tsbuildinfo",
    "tsc": "tsc",
    "eslint": "eslint --fix ./src/**/*.ts",
    "prettier": "prettier --log-level silent --write ./src",
    "build": "run-s clean tsc eslint prettier"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InHeap/es-cache.git"
  },
  "keywords": [
    "cache",
    "typescript",
    "ecmascript 6"
  ],
  "author": "Nitin Bansal",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/InHeap/es-cache/issues"
  },
  "homepage": "https://github.com/InHeap/es-cache#readme",
  "optionalDependencies": {
    "@types/memcached": "^2.2.10",
    "memcached": "^2.2.2",
    "redis": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.11",
    "typescript-eslint": "^8.62.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true
  }
}
