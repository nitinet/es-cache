{
  "compilerOptions": {
    "module": "node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "inlineSourceMap": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": true,
    "incremental": true,
    "strict": true,
    "rootDir": "./",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
